#include <iostream>
using namespace std;
double calcularMedia(int vector[], int n) {
    int suma = 0;
    for (int i = 0; i < n; i++) {
        suma += vector[i];
    }
    return (double)suma / n;
}
int main() {
    int n;
    cout << "Ingrese la cantidad de elementos del vector: ";
    cin >> n;
    int vector[n];
    cout << "Ingrese los elementos del vector:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "Elemento [" << i << "]: ";
        cin >> vector[i];
    }
    double media = calcularMedia(vector, n);
    cout << "La media de los elementos es: " << media << endl;
    return 0;
}
